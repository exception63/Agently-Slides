{
  "name": "@slidesmith/ir",
  "version": "0.0.0",
  "type": "module",
  "description": "Slidesmith canonical slide IR: TypeScript types, Zod schema, validation, anchor derivation, JSON Schema export.",
  "main": "./src/index.ts",
