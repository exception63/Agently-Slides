{
  "name": "slidesmith",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "AI-first HTML slides system: Markdown -> JSON IR -> portable single-file deck + synced transcript + dual-screen presenter.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "build:studio": "node scripts/build-studio.mjs",
    "sm": "tsx packages/cli/src/index.ts"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
