<!--
  ============================================================
  PRESENTER VIEW · 副屏 HTML 模板 · v0.3
  ============================================================
  使用方法：
    1. 复制本文件 → 重命名为 `演讲者模式.html`（或 presenter.html）
    2. 替换 4 个占位：
       {{SCRIPT_BASE}}      —— 讲稿 HTML 相对路径（例：'../01-讲稿/讲稿合集.html'）
       {{INITIAL_ANCHOR}}   —— 初始锚点（例：'s0-1'）
       {{SLIDE_MAP_LOCAL}}  —— SLIDE_MAP 数组（整块粘贴 · 含外层 [ ]）
       {{SEG_NAMES}}        —— 段名数组（例：['开场','prompt','agents','Case 01','Case 02']）
    3. 把它和主屏 slides HTML 放同目录（保证 BroadcastChannel + localStorage 同源）

  v0.3 新特性（vs v0.2.3）：
    - 反向联动：演讲者按键 / TOC 点击 → slides 联动翻页（双向通信）
    - 跟随拆分：正向跟随 + 反向跟随两个 toggle · 红绿色态
    - 同步拆分：正向同步 (S) + 反向同步 (D) 两个一次性按钮
    - Keywords (K)：当前激活板块的 <strong> 高亮（提词 · 不突兀）
    - 防回声：双向广播带 source 字段 · 不会循环
    - 键盘转发：iframe 焦点时讲稿端把按键转发给 parent · 翻页不失灵
  ============================================================
-->
<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>演讲者模式</title>
<style>
  :root {
    --bg: #1A1814;
    --bg-2: #25221C;
    --bg-3: #2F2B23;
    --line: #3F392E;
    --text: #F4ECD8;
    --text-soft: #B8AE93;
    --text-faint: #7A7464;
    --vermilion: #D44A5C;
    --gold: #D4A848;
    --jade: #6FAA82;
    --indigo: #7CA0C7;
    /* v0.3 状态色：toggle 按钮（跟随/Keywords）用 · 不刺眼 · 绿=开 红=关 */
    --state-on: #6FAA82;        /* 玉绿 · 已开启 */
    --state-on-dim: #4D7A5C;
    --state-off: #C76B5B;       /* 赤陶 · 已关闭（柔和的红 · 非主色 vermilion · 不抢眼） */
    --state-off-dim: #8E4A3D;
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; height: 100%; overflow: hidden; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: "PingFang SC", "Helvetica Neue", "Source Han Sans SC", sans-serif;
    font-size: 14px;
    -webkit-font-smoothing: antialiased;
  }
  .layout { display: grid; grid-template-rows: auto auto 1fr; height: 100vh; }

  /* Header */
  .phead {
    background: linear-gradient(180deg, var(--bg-2) 0%, var(--bg) 100%);
    border-bottom: 2px solid var(--vermilion);
    padding: 14px 24px;
    display: grid;
    grid-template-columns: 200px 1fr 200px 280px;
    gap: 24px;
    align-items: center;
  }
  .phead__col { min-width: 0; }
  .phead__label { font-size: 10px; letter-spacing: 3px; color: var(--text-faint); margin-bottom: 4px; font-weight: 600; }
  .phead__col--slide { border-right: 1px solid var(--line); padding-right: 24px; }
  .phead__num { font-family: "SF Mono", "Menlo", monospace; font-size: 32px; font-weight: 700; color: var(--text); line-height: 1; letter-spacing: 1px; }
  .phead__num #curIdx { color: var(--vermilion); }
  .phead__seg { margin-top: 8px; font-size: 12px; color: var(--text-soft); }
  .phead__seg #curSeg { display: inline-block; background: var(--vermilion); color: #fff; padding: 1px 8px; border-radius: 3px; margin-right: 4px; font-weight: 600; }

  .phead__col--title { text-align: center; padding: 0 12px; }
  .phead__title-prev, .phead__title-next { font-size: 12px; color: var(--text-faint); line-height: 1.4; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .phead__title-cur { font-family: "Source Han Serif SC", "Songti SC", serif; font-size: 22px; font-weight: 700; color: var(--gold); line-height: 1.3; margin: 6px 0; letter-spacing: 0.5px; }

  .phead__col--timer { text-align: center; border-left: 1px solid var(--line); border-right: 1px solid var(--line); padding: 0 16px; }
  .phead__timer { font-family: "SF Mono", "Menlo", monospace; font-size: 26px; font-weight: 700; color: var(--jade); line-height: 1; letter-spacing: 2px; }
  .phead__timer.paused { color: var(--text-faint); }
  .phead__timer-btns { margin-top: 8px; display: flex; justify-content: center; gap: 8px; }
  .phead__timer-btns button { background: transparent; color: var(--text-soft); border: 1px solid var(--line); padding: 3px 12px; font-size: 11px; border-radius: 3px; cursor: pointer; font-family: inherit; }
  .phead__timer-btns button:hover { background: var(--bg-3); color: var(--text); }

  .phead__col--ctrl { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
  .ctrl-btn { background: var(--bg-3); color: var(--text); border: 1px solid var(--line); padding: 6px 10px; font-size: 12px; border-radius: 3px; cursor: pointer; font-family: inherit; transition: all 0.15s; }
  .ctrl-btn:hover { background: var(--vermilion); border-color: var(--vermilion); color: #fff; }
  .ctrl-btn.locked { background: var(--gold); border-color: var(--gold); color: #1A1814; font-weight: 600; }
  /* v0.3 缩小的 A−/A＋（两个挤在一个 grid 单元里 · 给 Keywords 让位） */
  .ctrl-zoom-group { display: flex; gap: 4px; }
  .ctrl-zoom-group .ctrl-btn { flex: 1; padding: 6px 4px; font-size: 11px; }
  /* v0.3 跨整行按钮（旋转） */
  .ctrl-btn--wide { grid-column: 1 / -1; }
  /* v0.3 toggle 按钮的开/关状态色 — 正/反跟随 + Keywords 用 */
  .ctrl-btn.state-on  { background: var(--state-on);  border-color: var(--state-on-dim);  color: #14241A; font-weight: 600; }
  .ctrl-btn.state-on:hover  { background: var(--state-on-dim);  border-color: var(--state-on-dim);  color: #fff; }
  .ctrl-btn.state-off { background: var(--state-off); border-color: var(--state-off-dim); color: #2A1812; font-weight: 600; }
  .ctrl-btn.state-off:hover { background: var(--state-off-dim); border-color: var(--state-off-dim); color: #fff; }

  .phead__status { background: var(--bg-2); border-bottom: 1px solid var(--line); padding: 5px 24px; font-size: 11px; color: var(--text-faint); display: flex; align-items: center; justify-content: space-between; font-family: "SF Mono", "Menlo", monospace; letter-spacing: 0.5px; }
  .phead__status.connected { color: var(--jade); }
  .phead__status.locked { color: var(--gold); }
  .phead__status-right kbd { background: var(--bg-3); border: 1px solid var(--line); padding: 1px 6px; border-radius: 3px; font-family: inherit; margin: 0 2px; color: var(--text-soft); }

  /* Iframe */
  .pmain { position: relative; overflow: hidden; background: #FAF6EE; }
  iframe#scriptFrame { width: 100%; height: 100%; border: none; background: #FAF6EE; }

  /* Toast */
  .toast { position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%); background: rgba(26, 24, 20, 0.92); color: var(--gold); padding: 10px 20px; border-radius: 4px; border: 1px solid var(--gold); font-size: 13px; pointer-events: none; opacity: 0; transition: opacity 0.3s; z-index: 100; backdrop-filter: blur(8px); }
  .toast.show { opacity: 1; }

  /* ============================ 状态栏折叠（释放讲稿空间） · v0.2.3 新增 ============================ */
  /* H 键 或点击右上角 👁 按钮 · 把 .phead 4-列 header + .phead__status 状态行整体收起 */
  .layout { position: relative; }
  .phead, .phead__status {
    transition: max-height 0.32s ease-out, opacity 0.32s ease-out,
                padding 0.32s ease-out, border-color 0.32s ease-out;
    overflow: hidden;
  }
  body.collapsed .phead,
  body.collapsed .phead__status {
    max-height: 0;
    opacity: 0;
    padding-top: 0;
    padding-bottom: 0;
    border-bottom-color: transparent;
  }
  .hide-btn {
    position: absolute;
    top: 6px; right: 8px;
    width: 32px; height: 32px;
    border-radius: 50%;
    background: rgba(26, 24, 20, 0.55);
    color: #F4ECD8;
    border: 1px solid rgba(212, 168, 72, 0.45);
    cursor: pointer;
    z-index: 200;
    font-size: 14px;
    padding: 0; line-height: 1;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    transition: background 0.2s, transform 0.2s, color 0.2s, border-color 0.2s;
  }
  .hide-btn:hover { background: rgba(26, 24, 20, 0.88); transform: scale(1.05); border-color: var(--gold); }
  body.collapsed .hide-btn { background: rgba(212, 168, 72, 0.78); color: #1A1814; border-color: var(--gold); }

  /* ============================ 旋转 90° （iPad 竖向 sidecar） ============================ */
  /* v0.2.2 新增：transform 把 .layout 旋转 90° · transform-origin 设到 0,0 + left: 100vw 推回视口 */
  /* 宽高互换：旋转后 .layout 逻辑宽=100vh · 逻辑高=100vw */
  /* 物理上：用户把 iPad 从横向 sidecar 拧到竖向 · 看到的就是更高的内容 */
  body.rotated { overflow: hidden; }
  body.rotated .layout {
    position: fixed;
    top: 0;
    left: 100vw;
    width: 100vh;
    height: 100vw;
    transform: rotate(90deg);
    transform-origin: 0 0;
  }
  .layout { transition: transform 0.35s ease-out; }
  #rotateBtn { grid-column: span 2; }

  /* Compact */
  @media (max-width: 1100px) {
    .phead { grid-template-columns: 140px 1fr 180px 200px; gap: 16px; padding: 10px 16px; }
    .phead__num { font-size: 26px; }
    .phead__title-cur { font-size: 18px; }
    .phead__timer { font-size: 22px; }
  }
  @media (max-width: 880px) {
    .phead { grid-template-columns: 1fr 1fr; grid-template-rows: auto auto; }
    .phead__col--title { grid-column: 1 / -1; }
    .phead__col--slide { border-right: none; padding-right: 0; }
  }
</style>
</head>
<body>
<div class="layout">

  <header class="phead">
    <div class="phead__col phead__col--slide">
      <div class="phead__label">SLIDE</div>
      <div class="phead__num"><span id="curIdx">—</span>/<span id="totalIdx">?</span></div>
      <div class="phead__seg"><span id="curSeg">—</span><span id="segName">等待同步</span></div>
    </div>
    <div class="phead__col phead__col--title">
      <div class="phead__title-prev">‹ 上一张：<span id="prevTitle">—</span></div>
      <div class="phead__title-cur" id="curTitle">演讲者模式 · 等待主屏连接</div>
      <div class="phead__title-next">› 下一张：<span id="nextTitle">—</span></div>
    </div>
    <div class="phead__col phead__col--timer">
      <div class="phead__label">⏱ 演讲计时</div>
      <div class="phead__timer" id="timer">00:00:00</div>
      <div class="phead__timer-btns">
        <button id="timerToggle">暂停</button>
        <button id="timerReset">↻</button>
      </div>
    </div>
    <div class="phead__col phead__col--ctrl">
      <!-- v0.3 · 4 行 8 按钮：跟随 ×2 · 同步 ×2 · 缩放组 + Keywords · 旋转占整行 -->
      <button id="fwdFollowBtn" class="ctrl-btn" title="L 键切换 · 正向跟随：slides 翻页 → 讲稿自动滚动">→ 跟随</button>
      <button id="revFollowBtn" class="ctrl-btn" title="J 键切换 · 反向跟随：演讲者按键 → slides 自动跳">← 跟随</button>
      <button id="fwdSyncBtn"   class="ctrl-btn" title="S 键 · 正向同步：把讲稿跳到 slides 当前位置">→ 同步</button>
      <button id="revSyncBtn"   class="ctrl-btn" title="D 键 · 反向同步：把 slides 跳到讲稿当前位置">← 同步</button>
      <div class="ctrl-zoom-group">
        <button id="zoomOutBtn" class="ctrl-btn" title="缩小讲稿字体">A−</button>
        <button id="zoomInBtn"  class="ctrl-btn" title="放大讲稿字体">A＋</button>
      </div>
      <button id="cueBtn"    class="ctrl-btn" title="K 键切换 · 高亮当前激活板块的关键词（提词）">✦ Keywords</button>
      <button id="rotateBtn" class="ctrl-btn ctrl-btn--wide" title="O 键切换 · 旋转 90° · iPad 竖向 sidecar 用">⟲ 旋转 90°</button>
    </div>
  </header>

  <div class="phead__status" id="connStatus">
    <span id="connStatusText">⚪ 等待主屏 ……</span>
    <span class="phead__status-right">
      <kbd>L/J</kbd>正/反跟随 · <kbd>S/D</kbd>正/反同步 · <kbd>←→</kbd>翻页 · <kbd>K</kbd>关键词 · <kbd>+/-</kbd>缩放 · <kbd>O</kbd>旋转 · <kbd>Space</kbd>计时 · <kbd>H</kbd>隐藏栏
    </span>
  </div>

  <main class="pmain">
    <iframe id="scriptFrame" src="{{SCRIPT_BASE}}#{{INITIAL_ANCHOR}}"></iframe>
  </main>
  <button id="hideBtn" class="hide-btn" title="H 键切换 · 隐藏状态栏 · 释放更多讲稿空间">👁</button>
  <div class="toast" id="toast"></div>
</div>

<script>
  // ============================================================
  // 配置：本地副本 SLIDE_MAP（主屏断连时仍可用）
  // 直接整块粘贴你的 SLIDE_MAP 数组
  // ============================================================
  const SLIDE_MAP_LOCAL = {{SLIDE_MAP_LOCAL}};
  const SCRIPT_BASE = '{{SCRIPT_BASE}}';
  const SEG_NAMES = {{SEG_NAMES}};  // 例：['开场','prompt','agents','Case 01','Case 02']

  // ============================================================
  // 状态
  // ============================================================
  let lastIdx = -1;
  let lastAnchor = '';        // v0.2 · 用 anchor 比较代替 slideIdx · 鲁棒
  // v0.3 · 锁定拆为正/反两个跟随开关 · 都默认开启
  let forwardFollow = true;   // → 跟随：slides 翻页 → 讲稿滚动
  let reverseFollow = true;   // ← 跟随：演讲者按键 → slides 翻页
  let cueOn = false;          // ✦ Keywords：当前激活板块的 strong 高亮（默认关）
  let timerRunning = true;
  let timerStart = Date.now();
  let timerElapsed = 0;
  let zoom = 1.0;
  const $ = id => document.getElementById(id);
  const iframe = $('scriptFrame');

  // Toast
  let toastTimer = null;
  function toast(msg, ms = 1600) {
    const el = $('toast'); el.textContent = msg; el.classList.add('show');
    if (toastTimer) clearTimeout(toastTimer);
    toastTimer = setTimeout(() => el.classList.remove('show'), ms);
  }

  // ============================================================
  // 应用主屏发来的状态
  // v0.3 · 加 source 防回声判断 · 跟随条件改为 forwardFollow
  // ============================================================
  function applyState(s) {
    if (!s || typeof s.slideIdx !== 'number') return;
    // v0.3 防回声：忽略自己反向广播触发的 slides 回传
    if (s.source === 'presenter') return;
    lastIdx = s.slideIdx;

    // 更新 header 显示（总是更新 · 不受跟随开关影响）
    $('curIdx').textContent = s.slideIdx + 1;
    if (typeof s.total === 'number') $('totalIdx').textContent = s.total;
    $('curSeg').textContent = '段 ' + (s.segment ?? 0);
    $('segName').textContent = ' · ' + (SEG_NAMES[s.segment ?? 0] || '');
    $('curTitle').textContent = s.title || '—';
    $('prevTitle').textContent = s.prevTitle || '—';
    $('nextTitle').textContent = s.nextTitle || '—';

    const status = $('connStatus');
    $('connStatusText').textContent = forwardFollow
      ? '🟢 已连接 · 跟随翻页中 · 当前 slide ' + (s.slideIdx + 1) + '/' + (s.total || '?')
      : '⏸ 正向跟随关 · slides 翻页不再触发讲稿滚动 · 当前 slide ' + (s.slideIdx + 1);
    status.classList.add('connected');
    status.classList.toggle('locked', !forwardFollow);  // 复用 locked 视觉做"跟随关"提示

    // v0.2/v0.3 · 用 anchor 比较 + forwardFollow 开关
    if (forwardFollow && s.anchor && s.anchor !== lastAnchor) {
      jumpToAnchor(s.anchor);
      lastAnchor = s.anchor;
    }
  }

  function jumpToAnchor(anchor) {
    if (!anchor) return;
    // 主通道：postMessage（跨 file:// 目录最稳）
    try { iframe.contentWindow.postMessage({ type: 'fuquan-scroll', anchor: anchor }, '*'); } catch (e) {}
    // 兜底：location.hash
    try {
      const cw = iframe.contentWindow;
      if (cw && cw.location && cw.location.hash !== '#' + anchor) cw.location.hash = '#' + anchor;
    } catch (e) {}
  }

  // ============================================================
  // v0.3 · Anchor → slideIdx 反查
  // 支持：sN-x（直查 SLIDE_MAP_LOCAL）/ seg-N（段封面 · 取该段第一张）/ 附录 sN-data 返回 -1
  // ============================================================
  function resolveAnchorToSlideIdx(anchor) {
    if (!anchor) return -1;
    if (/^s\d+-/.test(anchor)) return SLIDE_MAP_LOCAL.indexOf(anchor);  // 附录类自然返回 -1
    const segMatch = anchor.match(/^seg-(\d+)$/);
    if (segMatch) {
      const segNum = segMatch[1];
      return SLIDE_MAP_LOCAL.findIndex(a => a.startsWith('s' + segNum + '-'));
    }
    return -1;
  }

  // ============================================================
  // 双通道接收：BroadcastChannel + localStorage event
  // ============================================================
  let bc = null;
  try { bc = new BroadcastChannel('fuquan-presenter-sync'); bc.onmessage = e => applyState(e.data); }
  catch (e) { console.warn('BroadcastChannel 不可用', e); }

  window.addEventListener('storage', e => {
    if (e.key !== 'fuquan-presenter-state' || !e.newValue) return;
    try { applyState(JSON.parse(e.newValue)); } catch (err) {}
  });

  // 启动时读缓存
  try {
    const cached = localStorage.getItem('fuquan-presenter-state');
    if (cached) applyState(JSON.parse(cached));
  } catch (e) {}

  // ============================================================
  // v0.3 · 跟随开关（→ 跟随 / ← 跟随 · 绿=开 红=关）
  // ============================================================
  function applyFollowBtn(btn, on, labelOn, labelOff) {
    btn.classList.toggle('state-on', on);
    btn.classList.toggle('state-off', !on);
    btn.textContent = on ? labelOn : labelOff;
  }
  function refreshFollowBtns() {
    applyFollowBtn($('fwdFollowBtn'), forwardFollow, '→ 跟随 开', '→ 跟随 关');
    applyFollowBtn($('revFollowBtn'), reverseFollow, '← 跟随 开', '← 跟随 关');
  }
  function toggleForwardFollow() {
    forwardFollow = !forwardFollow;
    refreshFollowBtns();
    try { localStorage.setItem('fuquan-presenter-fwdfollow', forwardFollow ? '1' : '0'); } catch(e){}
    toast(forwardFollow ? '→ 正向跟随 开 · slides 翻页讲稿自动跟' : '→ 正向跟随 关 · 你可以自由滚讲稿');
    // 重发当前状态刷新 status 行
    if (lastIdx >= 0) {
      applyState({
        slideIdx: lastIdx,
        total: parseInt($('totalIdx').textContent) || 0,
        segment: parseInt(($('curSeg').textContent || '段 0').replace('段 ', '')) || 0,
        anchor: SLIDE_MAP_LOCAL[lastIdx],
        title: $('curTitle').textContent,
        prevTitle: $('prevTitle').textContent,
        nextTitle: $('nextTitle').textContent,
        source: 'slides'
      });
    }
  }
  function toggleReverseFollow() {
    reverseFollow = !reverseFollow;
    refreshFollowBtns();
    try { localStorage.setItem('fuquan-presenter-revfollow', reverseFollow ? '1' : '0'); } catch(e){}
    toast(reverseFollow ? '← 反向跟随 开 · 演讲者键盘翻页同步到 slides' : '← 反向跟随 关 · 键盘只滚讲稿');
  }
  // 启动时恢复跟随状态
  try {
    if (localStorage.getItem('fuquan-presenter-fwdfollow') === '0') forwardFollow = false;
    if (localStorage.getItem('fuquan-presenter-revfollow') === '0') reverseFollow = false;
  } catch(e) {}
  refreshFollowBtns();
  $('fwdFollowBtn').addEventListener('click', toggleForwardFollow);
  $('revFollowBtn').addEventListener('click', toggleReverseFollow);

  // ============================================================
  // v0.3 · 反向广播 presenter → slides（{type:'jump-to-slide', source:'presenter'}）
  // ============================================================
  function broadcastSlideJump(slideIdx) {
    const payload = { type: 'jump-to-slide', slideIdx, ts: Date.now(), source: 'presenter' };
    if (bc) { try { bc.postMessage(payload); } catch(e){} }
    try { localStorage.setItem('fuquan-slide-jump', JSON.stringify(payload)); } catch(e){}
  }
  function reverseNav(dir) {
    if (lastIdx < 0) { toast('尚未收到主屏状态 · 请先在主屏翻一页'); return; }
    const total = parseInt($('totalIdx').textContent) || SLIDE_MAP_LOCAL.length;
    const target = Math.max(0, Math.min(total - 1, lastIdx + dir));
    if (target === lastIdx) return;
    broadcastSlideJump(target);
    lastIdx = target;   // 立即更新本地 · 避免连按时回声拖慢
  }

  // ============================================================
  // v0.3 · 正向同步（→ 同步：讲稿跳到 slides 当前位置）
  // ============================================================
  function forwardSync() {
    if (lastIdx < 0) { toast('尚未收到主屏状态'); return; }
    const anchor = SLIDE_MAP_LOCAL[lastIdx] || SLIDE_MAP_LOCAL[0];
    jumpToAnchor(anchor);
    lastAnchor = anchor;
    toast('→ 同步：讲稿已跳到 slide ' + (lastIdx + 1));
  }

  // ============================================================
  // v0.3 · 反向同步（← 同步：slides 跳到讲稿当前可视位置）
  // 流程：postMessage 查讲稿当前 anchor → 讲稿回 fuquan-current-anchor → 反查 slideIdx → 反向广播
  // ============================================================
  function reverseSync() {
    try { iframe.contentWindow.postMessage({ type: 'fuquan-query-current' }, '*'); } catch (e) {}
  }
  $('fwdSyncBtn').addEventListener('click', forwardSync);
  $('revSyncBtn').addEventListener('click', reverseSync);

  // ============================================================
  // v0.3 · 监听讲稿 iframe 回传：current-anchor（反向同步用）+ toc-jump（点击目录用）+ nav-key（焦点在 iframe 时键盘转发）
  // ============================================================
  window.addEventListener('message', e => {
    if (!e || !e.data) return;
    if (e.data.type === 'fuquan-current-anchor' && e.data.anchor) {
      const idx = resolveAnchorToSlideIdx(e.data.anchor);
      if (idx < 0) { toast('← 同步：讲稿当前位置无对应 slide'); return; }
      broadcastSlideJump(idx);
      lastIdx = idx;
      toast('← 同步：slides 跳到第 ' + (idx + 1) + ' 张');
    } else if (e.data.type === 'fuquan-toc-jump' && e.data.anchor) {
      const idx = resolveAnchorToSlideIdx(e.data.anchor);
      if (idx < 0) return;  // 附录类无对应 slide · 静默忽略（讲稿原生跳锚仍有效）
      if (idx === lastIdx) return;
      broadcastSlideJump(idx);
      lastIdx = idx;
      toast('TOC：slides 跳到第 ' + (idx + 1) + ' 张');
    } else if (e.data.type === 'fuquan-nav-key' && typeof e.data.key === 'string') {
      handleKey(e.data.key);
    }
  });

  // ============================================================
  // 计时器
  // ============================================================
  function fmt(s) {
    const h = String(Math.floor(s / 3600)).padStart(2, '0');
    const m = String(Math.floor((s % 3600) / 60)).padStart(2, '0');
    const sec = String(s % 60).padStart(2, '0');
    return `${h}:${m}:${sec}`;
  }
  function updateTimer() {
    let total = timerElapsed;
    if (timerRunning) total += Math.floor((Date.now() - timerStart) / 1000);
    $('timer').textContent = fmt(total);
  }
  setInterval(updateTimer, 1000);

  function toggleTimer() {
    if (timerRunning) {
      timerElapsed += Math.floor((Date.now() - timerStart) / 1000);
      timerRunning = false;
      $('timerToggle').textContent = '继续';
      $('timer').classList.add('paused');
      toast('⏸ 计时已暂停');
    } else {
      timerStart = Date.now();
      timerRunning = true;
      $('timerToggle').textContent = '暂停';
      $('timer').classList.remove('paused');
      toast('▶ 计时继续');
    }
  }
  function resetTimer() {
    timerElapsed = 0; timerStart = Date.now(); timerRunning = true;
    $('timerToggle').textContent = '暂停';
    $('timer').classList.remove('paused');
    updateTimer();
    toast('↻ 计时已重置');
  }
  $('timerToggle').addEventListener('click', toggleTimer);
  $('timerReset').addEventListener('click', resetTimer);

  // ============================================================
  // 字号缩放
  // ============================================================
  function zoomIn()  { zoom = Math.min(2.0, zoom + 0.1); iframe.style.zoom = zoom; toast('字号 ' + Math.round(zoom * 100) + '%'); }
  function zoomOut() { zoom = Math.max(0.7, zoom - 0.1); iframe.style.zoom = zoom; toast('字号 ' + Math.round(zoom * 100) + '%'); }
  $('zoomInBtn').addEventListener('click', zoomIn);
  $('zoomOutBtn').addEventListener('click', zoomOut);

  // ============================================================
  // v0.3 · Keywords 高亮（K 键 · 默认关 · 仅当前激活板块的 <strong>）
  // ============================================================
  function applyCue() {
    const btn = $('cueBtn');
    btn.classList.toggle('state-on', cueOn);
    btn.classList.toggle('state-off', !cueOn);
    btn.textContent = cueOn ? '✦ Keywords 开' : '✦ Keywords 关';
    try { iframe.contentWindow.postMessage({ type: 'fuquan-cue', on: cueOn }, '*'); } catch (e) {}
  }
  function toggleCue() {
    cueOn = !cueOn;
    applyCue();
    try { localStorage.setItem('fuquan-presenter-cue', cueOn ? '1' : '0'); } catch(e){}
    toast(cueOn ? '✦ 关键词高亮 开 · 当前激活板块的 strong 会亮' : '✦ 关键词高亮 关');
  }
  $('cueBtn').addEventListener('click', toggleCue);
  // 启动时从 localStorage 恢复
  try { if (localStorage.getItem('fuquan-presenter-cue') === '1') cueOn = true; } catch(e) {}
  applyCue();  // 首次渲染（默认关 = 红色态）
  iframe.addEventListener('load', applyCue);  // iframe 切换/刷新后重发当前 cue 状态

  // ============================================================
  // 旋转 90° （iPad 竖向 sidecar 用）· v0.2.2 新增
  // ============================================================
  let rotated = false;
  function applyRotation() {
    document.body.classList.toggle('rotated', rotated);
    const btn = $('rotateBtn');
    if (rotated) {
      btn.classList.add('locked');  // 复用 locked 样式做"激活态"
      btn.textContent = '⟲ 已旋转 · 点击复位';
    } else {
      btn.classList.remove('locked');
      btn.textContent = '⟲ 旋转 90°';
    }
    // 旋转后讲稿滚动位置可能错乱 · 重新跳到当前锚点
    setTimeout(() => {
      if (lastAnchor) {
        const prev = lastAnchor;
        lastAnchor = '';
        jumpToAnchor(prev);
        lastAnchor = prev;
      }
    }, 380);
  }
  function toggleRotation() {
    rotated = !rotated;
    applyRotation();
    try { localStorage.setItem('fuquan-presenter-rotated', rotated ? '1' : '0'); } catch(e){}
    toast(rotated ? '⟲ 已旋转 · 把 iPad 拧到竖向' : '⟲ 已复位 · 横向');
  }
  $('rotateBtn').addEventListener('click', toggleRotation);

  // 启动时从 localStorage 恢复旋转状态
  try {
    if (localStorage.getItem('fuquan-presenter-rotated') === '1') {
      rotated = true;
      applyRotation();
    }
  } catch(e) {}

  // ============================================================
  // 状态栏隐藏 / 显示 · v0.2.3 新增
  // ============================================================
  let collapsed = false;
  function applyCollapse() {
    document.body.classList.toggle('collapsed', collapsed);
    const btn = $('hideBtn');
    btn.textContent = collapsed ? '☰' : '👁';
    btn.title = collapsed
      ? 'H 键或点击 · 显示状态栏（计时器 / 翻页信息）'
      : 'H 键或点击 · 隐藏状态栏 · 释放更多讲稿空间';
  }
  function toggleCollapse() {
    collapsed = !collapsed;
    applyCollapse();
    try { localStorage.setItem('fuquan-presenter-collapsed', collapsed ? '1' : '0'); } catch(e){}
    toast(collapsed ? '☰ 状态栏已隐藏 · 按 H 或点 ☰ 复原' : '👁 状态栏已显示');
  }
  $('hideBtn').addEventListener('click', toggleCollapse);

  // 启动时恢复隐藏状态
  try {
    if (localStorage.getItem('fuquan-presenter-collapsed') === '1') {
      collapsed = true;
      applyCollapse();
    }
  } catch(e) {}

  // ============================================================
  // v0.3 · 键盘处理（统一入口 · keydown + iframe 转发都走这里）
  // 方向键/翻页笔：反向跟随开 → 联动 slides；关 → 仅滚讲稿一屏
  // ============================================================
  function handleKey(key) {
    if (key === 'ArrowRight' || key === 'ArrowDown' || key === 'PageDown') {
      if (reverseFollow) { reverseNav(+1); }
      else { iframe.contentWindow.scrollBy(0, iframe.clientHeight * 0.85); }
      return true;
    }
    if (key === 'ArrowLeft' || key === 'ArrowUp' || key === 'PageUp') {
      if (reverseFollow) { reverseNav(-1); }
      else { iframe.contentWindow.scrollBy(0, -iframe.clientHeight * 0.85); }
      return true;
    }
    const k = key.toLowerCase();
    if (k === 'l') { toggleForwardFollow(); return true; }
    if (k === 'j') { toggleReverseFollow(); return true; }
    if (k === 's') { forwardSync(); return true; }
    if (k === 'd') { reverseSync(); return true; }
    if (k === ' ') { toggleTimer(); return true; }
    if (k === 'r') { resetTimer(); return true; }
    if (k === '=' || k === '+') { zoomIn(); return true; }
    if (k === '-' || k === '_') { zoomOut(); return true; }
    if (k === 'o') { toggleRotation(); return true; }
    if (k === 'h') { toggleCollapse(); return true; }
    if (k === 'k') { toggleCue(); return true; }
    return false;
  }
  // 1) 原生 keydown（焦点在演讲者模式 header / 空白区）
  document.addEventListener('keydown', e => {
    if (e.target.matches('input, textarea, select')) return;
    if (handleKey(e.key)) e.preventDefault();
  });
  // 2) 转发：iframe（讲稿）焦点时 · 讲稿端 postMessage 'fuquan-nav-key' 给我们（见上面的 message 监听）

  setTimeout(() => { if (lastIdx < 0) toast('💡 回到主屏翻一次页 · 副屏即同步', 3000); }, 1500);
</script>
</body>
</html>
